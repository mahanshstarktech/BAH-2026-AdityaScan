# Copy this file to .env.training.local and fill in your own values.
# .env.training.local is gitignored. Do not commit real credentials.

PRADAN_USER=your_pradan_username
PRADAN_PASS=your_pradan_password

# Optional, for NASA JSOC/SDO SHARP downloads if/when SHARP is enabled.
# Use your email address registered/accepted by JSOC.
JSOC_EMAIL=your_email@example.com
